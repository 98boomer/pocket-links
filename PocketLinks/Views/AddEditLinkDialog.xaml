<Window x:Class="PocketLinks.Views.AddEditLinkDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PocketLinks.Converters"
        Title="{Binding WindowTitle}"
        Width="420" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource PanelBackground}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Name -->
        <TextBlock Grid.Row="0" Text="Name" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimary}"/>
        <TextBox Grid.Row="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                 Padding="6,4" FontSize="13" Margin="0,0,0,10"/>

        <!-- URL / Path -->
        <TextBlock Grid.Row="2" Text="URL or File Path" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimary}"/>
        <Grid Grid.Row="3" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Text="{Binding Target, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" FontSize="13"/>
            <Button Grid.Column="1" Content="Browse..."
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding BrowseCommand}"
                    Margin="6,0,0,0"/>
        </Grid>

        <!-- Category -->
        <TextBlock Grid.Row="4" Text="Category" FontSize="13" Margin="0,0,0,4" Foreground="{DynamicResource TextPrimary}"/>
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0"
                       ItemsSource="{Binding Categories}"
                       SelectedItem="{Binding SelectedCategory}"
                       Padding="6,4" FontSize="13"
                       Visibility="{Binding IsNewCategory, Converter={StaticResource InverseBoolToVis}}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={x:Static conv:CategoryDisplayConverter.Instance}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <TextBox Grid.Column="0"
                     Text="{Binding NewCategory, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4" FontSize="13"
                     Visibility="{Binding IsNewCategory, Converter={StaticResource BoolToVis}}"/>
            <CheckBox Grid.Column="1"
                      Content="New"
                      IsChecked="{Binding IsNewCategory}"
                      VerticalAlignment="Center"
                      Margin="8,0,0,0"/>
        </Grid>

        <!-- Error message -->
        <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}"
                   Foreground="Red" FontSize="12"
                   TextWrapping="Wrap"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,10"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"/>
            <Button Content="Save"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding SaveCommand}"/>
        </StackPanel>
    </Grid>
</Window>
