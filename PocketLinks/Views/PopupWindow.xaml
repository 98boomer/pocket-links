<Window x:Class="PocketLinks.Views.PopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PocketLinks.ViewModels"
        xmlns:models="clr-namespace:PocketLinks.Models"
        xmlns:conv="clr-namespace:PocketLinks.Converters"
        Title="Pocket Links"
        Width="380" Height="440"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated">

    <Window.Resources>
        <conv:EmptyToCollapsedConverter x:Key="EmptyToCollapsedConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolVis"/>
    </Window.Resources>

    <!-- Rounded border with shadow, matching Win11 flyout style -->
    <Border Background="{DynamicResource PanelBackground}"
            CornerRadius="8"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.25" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Padding="12,10,12,4">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="Pocket Links"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               VerticalAlignment="Center"/>

                    <!-- Theme toggle (sun/moon) -->
                    <Button Grid.Column="1"
                            Command="{Binding ToggleThemeCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            ToolTip="Toggle light / dark mode">
                        <Grid>
                            <TextBlock Text="&#x2600;"
                                       FontSize="16"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Visibility="{Binding IsDarkMode, Converter={StaticResource InverseBoolVis}}"/>
                            <TextBlock Text="&#x1F319;"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextSecondary}"
                                       Visibility="{Binding IsDarkMode, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Button>

                    <!-- Edit / Done toggle -->
                    <Button Grid.Column="2"
                            Command="{Binding ToggleEditModeCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Margin="4,0,0,0">
                        <Grid>
                            <TextBlock Text="Edit"
                                       FontSize="13"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolVis}}"/>
                            <TextBlock Text="Done"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <!-- Search box -->
            <Border Grid.Row="1" Padding="10,4,10,6">
                <TextBox Style="{StaticResource SearchBox}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>

            <!-- Link list -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="6,0"
                          Background="Transparent">
                <ScrollViewer.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add Link..." Click="AddLink_Click"/>
                    </ContextMenu>
                </ScrollViewer.ContextMenu>
                <ItemsControl ItemsSource="{Binding LinksView}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource CategoryHeaderStyle}"
                                               Text="{Binding Name}"
                                               Visibility="{Binding Name, Converter={StaticResource EmptyToCollapsedConverter}}"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:LinkItem}">
                            <Border Style="{StaticResource LinkTile}"
                                    MouseLeftButtonUp="LinkTile_MouseLeftButtonUp"
                                    Tag="{Binding}">
                                <Border.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="Copy Link" Click="CopyLink_Click" Tag="{Binding}"/>
                                        <MenuItem Header="Open" Click="OpenLink_Click" Tag="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="Edit..." Click="EditLink_Click" Tag="{Binding}"/>
                                        <MenuItem Header="Delete" Click="DeleteLink_Click" Tag="{Binding}"/>
                                    </ContextMenu>
                                </Border.ContextMenu>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Minus (delete) button — iOS-style, visible in edit mode -->
                                    <Button Grid.Column="0"
                                            Command="{Binding DataContext.RemoveLinkCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            VerticalAlignment="Center"
                                            Margin="0,0,6,0"
                                            Padding="0"
                                            Width="22" Height="22">
                                        <Grid>
                                            <Ellipse Fill="#FF3B30" Width="20" Height="20"/>
                                            <Rectangle Fill="White" Width="10" Height="2" RadiusX="1" RadiusY="1"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <!-- Icon -->
                                    <Image Grid.Column="1"
                                           Source="{Binding IconSource}"
                                           Width="20" Height="20"
                                           Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           VerticalAlignment="Center"/>

                                    <!-- Name & target -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Target}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="0,1,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Status bar -->
            <Border Grid.Row="3" Padding="4,0,4,4">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource StatusText}"/>
                    <TextBlock HorizontalAlignment="Right"
                               Style="{StaticResource StatusText}"
                               Foreground="{DynamicResource TextSecondary}"
                               Text="Click = copy · Ctrl+Click = open"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
